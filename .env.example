# 127.0.0.1 — только локально; 0.0.0.0 — доступ с других машин (firewall!)
APP_HOST=127.0.0.1
APP_PORT=8080
DATABASE_URL=sqlite:///./database/tunnelkeeper.db
SESSION_SECRET_KEY=change-me-please
SESSION_MAX_IDLE_SECONDS=1800
LOGIN_RATE_LIMIT_ATTEMPTS=5
LOGIN_RATE_LIMIT_WINDOW_SECONDS=300
READONLY_MODE=false
SECURE_COOKIES=false
LOG_LEVEL=INFO

# Web UI (ephemeral login printed on startup) and/or JSON API for remote panels
ENABLE_WEB_UI=true
ENABLE_API=false
# Required when ENABLE_API=true (min 16 characters). Generate: python3 -c "import secrets; print(secrets.token_urlsafe(32))"
API_TOKEN=

# sshd: PermitOpen via Match User snippets (requires root + Include in sshd_config)
SSHD_GENERATED_DIR=/etc/ssh/sshd_config.d/generated
SSHD_MAIN_CONFIG=/etc/ssh/sshd_config
SSHD_INCLUDE_SNIPPET=Include /etc/ssh/sshd_config.d/*.conf
SSHD_RELOAD_ON_CHANGE=true
